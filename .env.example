# Supabase Configuration Example
# Copy this file to .env and replace with your actual values

# Your Supabase project URL (e.g., https://your-project-id.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Legal/public web metadata used in-app and for Play submission consistency
EXPO_PUBLIC_WEB_BASE_URL=https://zenlit.app
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://zenlit.app/privacy
EXPO_PUBLIC_TERMS_URL=https://zenlit.app/terms
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://zenlit.app/delete-account
EXPO_PUBLIC_SUPPORT_EMAIL=support@zenlit.app

# This app uses email-based OTP only; no Google OAuth configuration
